# Dependencies
node_modules/

# Build output
dist/

# Environment variables and secrets — never commit real values.
# Only `.env.example` files (no real secrets) are allowed in git.
.env
.env.*
!.env.example
!.env.*.example

# Test/coverage output
coverage/
.nyc_output/

# Generated codegen artifacts
generated-schema/

# Tooling artifacts
*.zip

# Local dev stack (embedded Postgres data + binaries)
.dev-stack/

# Superpowers brainstorming companion artifacts (local only)
.superpowers/
_screenshots/

# Logs
logs/
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor/IDE
.idea/
.vscode/

# Keys and certificates
*.pem
*.key
*.crt

# Other sensitive files
.envrc
.secret
secrets.json
credentials.json
