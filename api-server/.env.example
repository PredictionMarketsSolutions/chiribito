# Chiribito — API Server (Express + TypeORM) environment variables
# Copy to .env and fill in real values. Never commit .env.

# Runtime
NODE_ENV=development
PORT=3000

# JWT — must match game server JWT_SECRET.
# Generate with: openssl rand -base64 48
JWT_SECRET=

# Internal server-to-server auth — same value as game server INTERNAL_API_SECRET
INTERNAL_API_SECRET=

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=chiribito
DB_SSL=false

# Bootstrap database (used only by scripts/init-db.ts, never at runtime)
# DB_ROOT_USER=postgres
# DB_ROOT_PASSWORD=postgres
# DB_ROOT_DATABASE=postgres

# Redis — required in production for rate limiting and session/ranking cache
REDIS_URL=

# CORS — production only. Comma-separated list of allowed origins.
ALLOWED_ORIGINS=

# Frontend URL — used in password reset links
FRONTEND_URL=http://localhost:5173

# Email (Resend) — required for welcome and password reset emails
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@chiribito.com

# Token-version cache (mirror of game-server settings). Default: true.
# AUTH_TOKEN_VERSION_CACHE_TTL_MS=60000

# Logging
LOG_LEVEL=info
LOGTAIL_SOURCE_TOKEN=
