# Chiribito — Game Server (Colyseus) environment variables
# Copy to .env and fill in real values. Never commit .env.

# Runtime
NODE_ENV=development
PORT=2567

# JWT — must match api-server JWT_SECRET (used to verify tokens from clients).
# Generate with: openssl rand -base64 48
JWT_SECRET=

# API server location (game server validates tokens by calling api-server)
API_URL=http://localhost:3000

# Internal server-to-server auth (game server → api-server stats)
# Generate with: openssl rand -base64 48
INTERNAL_API_SECRET=

# Database (game server reads only for env validation; api-server owns writes)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_NAME=chiribito

# Redis — required in production for session store and presence.
# Leave empty in local dev to fall back to MemoryStore.
REDIS_URL=
REDIS_PREFIX=chiribito

# CORS — production only. Comma-separated list of allowed origins.
ALLOWED_ORIGINS=

# Game tuning (optional — defaults in src/config/env.ts)
# TURN_TIMEOUT_MS=60000
# HEARTBEAT_INTERVAL_MS=30000
# HEARTBEAT_TIMEOUT_MS=180000
# ACTION_COOLDOWN_MS=200
# ALLIN_REVEAL_DELAY_MS=1000
# AUTH_REQUEST_TIMEOUT_MS=8000

# Logging
LOG_LEVEL=info
# Better Stack (Logtail) — leave empty to log only to stdout
LOGTAIL_SOURCE_TOKEN=

# Monitor / playground auth — required in production to expose /colyseus and /playground.
# If empty, those endpoints are disabled in non-development environments.
MONITOR_USER=
MONITOR_PASSWORD=

# Tests only — skip env validation
# DISABLE_ENV_VALIDATION=false
