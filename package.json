{
  "private": true,
  "name": "my-app",
  "version": "0.16.0",
  "description": "npm init template for bootstrapping an empty Colyseus project",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:prod": "cross-env NODE_ENV=production node dist/index.js",
    "dev:prod": "cross-env NODE_ENV=production tsx watch src/index.ts",
    "tsx": "tsx watch src/index.ts",
    "login-and-join": "tsx scripts/login-and-join.ts",
    "test:sidepot": "tsx scripts/test-sidepot-scenarios.ts",
    "test:sidepot:fuzz": "tsx scripts/test-sidepot-fuzz.ts",
    "test:betting-rules": "tsx scripts/test-bet-sizing-rules.ts",
    "test:game-pro": "npm run test:sidepot && npm run test:betting-rules && npm run test:sidepot:fuzz",
    "loadtest": "tsx loadtest/example.ts --room my_room --numClients 99",
    "build": "npm run build:game && npm run build:api",
    "build:game": "tsc",
    "build:api": "cd api-server && npm install && npm run build",
    "start:api": "cd api-server && npm start",
    "dev:api": "cd api-server && npm run dev",
    "build:start": "npm run build && npm start",
    "test": "mocha -r tsx ts-node/register test/**_test.ts --exit --timeout 15000",
    "test:jest": "jest",
    "test:jest:watch": "jest --watch",
    "test:jest:coverage": "jest --coverage",
    "logs": "node scripts/view-logs.js all",
    "logs:error": "node scripts/view-logs.js error",
    "logs:watch": "node scripts/view-logs.js watch",
    "logs:search": "node scripts/view-logs.js search",
    "schema-codegen": "schema-codegen src/rooms/schema/* --csharp --output ../Assets/Example/"
  },
  "author": "",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/colyseus/create-colyseus/issues"
  },
  "homepage": "https://github.com/colyseus/create-colyseus#readme",
  "devDependencies": {
    "@colyseus/loadtest": "^0.16.0",
    "@colyseus/testing": "^0.16.0",
    "@types/cors": "^2.8.18",
    "@types/dotenv": "^6.1.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/mocha": "^8.2.3",
    "@types/node": "^22.15.24",
    "copyfiles": "^2.4.1",
    "cross-env": "^7.0.3",
    "mocha": "^11.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^3.12.7",
    "typescript": "^5.8.3",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "@colyseus/auth": "^0.16.0",
    "@colyseus/core": "^0.16.0",
    "@colyseus/monitor": "^0.16.0",
    "@colyseus/playground": "^0.16.0",
    "@colyseus/schema": "^3.0.37",
    "@colyseus/tools": "^0.16.0",
    "@colyseus/ws-transport": "^0.16.5",
    "@types/express": "^4.17.22",
    "@types/express-session": "^1.18.2",
    "bcryptjs": "^3.0.3",
    "colyseus.js": "^0.16.17",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.2",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.24",
    "winston": "^3.19.0",
    "zod": "^3.24.2",
    "@logtail/node": "^0.5.4",
    "@logtail/winston": "^0.5.4"
  },
  "workspaces": [
    "api-server"
  ]
}
